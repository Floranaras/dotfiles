#!/usr/bin/env bash

################################################################################
# FILE CONVERTER - Multi-format file conversion tool
################################################################################
#
# A CLI tool for converting between video, audio, image, and document formats
# with optional Discord-friendly compression.
#
# AUTHOR: Amane Kai / 雨音カイ
# VERSION: 1.1.0 (Refactored)
# DEPENDENCIES: ffmpeg, ffprobe, bc, libreoffice (for documents)
#
################################################################################

# --- Strict Mode ---
set -euo pipefail

# --- Help Menu ---
show_help() {
    cat << 'EOF'
FILE CONVERTER - Multi-format conversion tool
Version 1.1.0

USAGE:
    fconv <input_file> <output_format/file> [options]

SUPPORTED FORMATS:
    Video:      mp4, mkv, mov, webm
    Audio:      mp3, wav, ogg, m4a
    Images:     png, jpeg, jpg, webp
    Documents:  pdf, docx, doc, odt

OPTIONS:
    -d, --discord              Enable Discord compression (10MB default)
    -s, --size <MB>            Target size in MB (Default: 10)
    
    -b, --bitrate <kbps>       Manual video bitrate (e.g., 2000)
    -crf <0-51>                Constant Rate Factor (Default: 23)
    -r, --res <WxH>            Resolution (e.g., 1280x720)
    
    -a, --audio <kbps>         Audio bitrate (Default: 192)
    -q, --quality <0-9>        MP3 VBR quality (Default: 2, 0=best)
    
    -o, --output <file>        Specify custom output filename
    -h, --help                 Show this help message

EOF
}

# --- Helper Functions ---
die() { echo -e "✖ Error: $1" >&2; exit 1; }

check_deps() {
    for tool in ffmpeg ffprobe bc; do
        command -v "$tool" &>/dev/null || die "$tool is not installed."
    done
}

# --- Initialization ---
check_deps

[[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]] && { show_help; exit 0; }

INPUT="$1"; shift
[[ -f "$INPUT" ]] || die "File '$INPUT' not found."

# Metadata Extraction
FILENAME=$(basename -- "$INPUT")
INPUT_EXT="${FILENAME##*.}"
NAME="${FILENAME%.*}"

# Defaults
DISCORD_MODE=false
TARGET_SIZE=10
AUDIO_BITRATE=192
VIDEO_BITRATE=""
MP3_QUALITY=2
CRF=23
RESOLUTION=""
OUTPUT_FILE=""
OUTPUT_FORMAT=""

# --- Argument Parsing ---

# Handle positional output (e.g., fconv file.mov mp4)
if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
    if [[ "$1" == *.* ]]; then
        OUTPUT_FILE="$1"
        OUTPUT_FORMAT="${1##*.}"
    else
        OUTPUT_FORMAT="$1"
    fi
    shift
fi

# Parse Flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        -d|--discord)    DISCORD_MODE=true ;;
        -s|--size)       TARGET_SIZE="$2"; shift ;;
        -b|--bitrate)    VIDEO_BITRATE="$2"; shift ;;
        -a|--audio)      AUDIO_BITRATE="$2"; shift ;;
        -q|--quality)    MP3_QUALITY="$2"; shift ;;
        -crf)            CRF="$2"; shift ;;
        -r|--res)        RESOLUTION="$2"; shift ;;
        -o|--output)     OUTPUT_FILE="$2"; OUTPUT_FORMAT="${2##*.}"; shift ;;
        *)               die "Unknown option: $1" ;;
    esac
    shift
done

# Finalize naming logic
OUTPUT_FORMAT="${OUTPUT_FORMAT:-$INPUT_EXT}"
OUTPUT_FILE="${OUTPUT_FILE:-${NAME}.${OUTPUT_FORMAT}}"

# --- Conversion Engines ---

handle_video() {
    local cmd=(ffmpeg -i "$INPUT" -y -hide_banner -loglevel warning)
    
    [[ -n "$RESOLUTION" ]] && cmd+=(-vf "scale=$RESOLUTION")

    if [[ -n "$VIDEO_BITRATE" ]]; then
        cmd+=(-c:v libx264 -b:v "${VIDEO_BITRATE}k")
    elif [[ "$DISCORD_MODE" == true ]]; then
        echo "Calculating Discord compression for ${TARGET_SIZE}MB..."
        local dur
        dur=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$INPUT")
        # Formula: (TargetMB * 8192 / duration) - AudioBitrate
        local bitrate
        bitrate=$(echo "($TARGET_SIZE * 8192 / $dur) - $AUDIO_BITRATE" | bc | cut -d'.' -f1)
        [[ $bitrate -lt 150 ]] && bitrate=150 # Minimum threshold
        cmd+=(-c:v libx264 -b:v "${bitrate}k" -maxrate "${bitrate}k" -bufsize "$((bitrate * 2))k")
    else
        cmd+=(-c:v libx264 -crf "$CRF")
    fi

    cmd+=(-c:a aac -b:a "${AUDIO_BITRATE}k" -movflags +faststart "$OUTPUT_FILE")
    "${cmd[@]}"
}

handle_audio() {
    ffmpeg -i "$INPUT" -vn -y -hide_banner \
        -c:a libmp3lame -q:a "$MP3_QUALITY" -b:a "${AUDIO_BITRATE}k" \
        "$OUTPUT_FILE"
}

handle_image() {
    ffmpeg -i "$INPUT" -y -hide_banner "$OUTPUT_FILE"
}

handle_document() {
    command -v libreoffice &>/dev/null || die "LibreOffice required for documents."
    
    libreoffice --headless --convert-to "$OUTPUT_FORMAT" "$INPUT" --outdir "."
    
    # Handle custom renaming if output name differs from default
    local expected="${NAME}.${OUTPUT_FORMAT}"
    [[ "$OUTPUT_FILE" != "$expected" && -f "$expected" ]] && mv "$expected" "$OUTPUT_FILE"
}

# --- Main Entry ---

echo "Converting: $INPUT ➜ $OUTPUT_FILE"

case "${OUTPUT_FORMAT,,}" in
    mp4|mkv|mov|webm)  handle_video ;;
    mp3|wav|ogg|m4a)   handle_audio ;;
    png|jpg|jpeg|webp) handle_image ;;
    pdf|docx|doc|odt)  handle_document ;;
    *) die "Unsupported format: $OUTPUT_FORMAT" ;;
esac

# Cleanup/Verification
if [[ -f "$OUTPUT_FILE" ]]; then
    final_size=$(du -h "$OUTPUT_FILE" | cut -f1)
    echo "✔ Success: $OUTPUT_FILE ($final_size)"
else
    die "Conversion failed."
fi
