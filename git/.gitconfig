[user]
	name = Floranaras
	email = carlosranara0@gmail.com
[credential]
	helper = store
[alias]
	st = status
    ad = add
    br = branch
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
    ci = commit
    co = checkout
    brd = "!f() { git push origin --delete \"$1\" && git branch -d \"$1\"; }; f"
[fetch]
	prune = true

