#!/usr/bin/env bash

################################################################################
# FCONV - Professional Multi-format Converter (v1.2.5 - GIF & MacOS Patch)
################################################################################
set -euo pipefail

# --- UI Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

die() { echo -e "${RED}✖ Error: $1${NC}" >&2; exit 1; }
info() { echo -e "${BLUE}➜ $1${NC}"; }
success() { echo -e "${GREEN}✔ $1${NC}"; }

get_libre_cmd() {
    if command -v soffice &>/dev/null; then echo "soffice"
    elif command -v libreoffice &>/dev/null; then echo "libreoffice"
    else echo ""; fi
}

check_deps() {
    for tool in ffmpeg ffprobe bc; do
        command -v "$tool" &>/dev/null || die "$tool is not installed. Run: brew install $tool"
    done
}

check_deps
[[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]] && { 
    echo -e "${BLUE}Usage:${NC} fconv <input_file> <output_format/file> [options]"; exit 0; 
}

INPUT="$1"; shift
[[ -f "$INPUT" ]] || die "File '$INPUT' not found."

FILENAME=$(basename -- "$INPUT")
NAME="${FILENAME%.*}"
INPUT_EXT="${FILENAME##*.}"

# Defaults
AUDIO_BITRATE=128
DISCORD_MODE=false
TARGET_SIZE=10
VIDEO_BITRATE=""
CRF=23
RESOLUTION=""
OUTPUT_FILE=""
OUTPUT_FORMAT=""

# --- Argument Parsing ---
if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
    if [[ "$1" == *.* ]]; then
        OUTPUT_FILE="$1"; OUTPUT_FORMAT="${1##*.}"
    else
        OUTPUT_FORMAT="$1"
    fi
    shift
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -d|--discord) DISCORD_MODE=true ;;
        -s|--size)    TARGET_SIZE="$2"; shift ;;
        -b|--bitrate) VIDEO_BITRATE="$2"; shift ;;
        -a|--audio)   AUDIO_BITRATE="$2"; shift ;;
        -r|--res)     RESOLUTION="$2"; shift ;;
        -o|--output)  OUTPUT_FILE="$2"; OUTPUT_FORMAT="${2##*.}"; shift ;;
        *) shift ;;
    esac
    shift
done

OUTPUT_FORMAT="${OUTPUT_FORMAT:-$INPUT_EXT}"
FMT_LOWER=$(echo "$OUTPUT_FORMAT" | tr '[:upper:]' '[:lower:]')
[[ -z "$OUTPUT_FILE" ]] && OUTPUT_FILE="${NAME}.${FMT_LOWER}"

# Safety: Avoid overwriting input
IN_REAL=$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")
OUT_DIR=$(dirname "$OUTPUT_FILE"); mkdir -p "$OUT_DIR"
OUT_REAL=$(cd "$OUT_DIR" && pwd)/$(basename "$OUTPUT_FILE")
[[ "$IN_REAL" == "$OUT_REAL" ]] && OUTPUT_FILE="${NAME}_converted.${FMT_LOWER}"

# --- Engines ---

handle_video() {
    local filters=""
    # Handle Resolution & 16:9 Padding
    if [[ -n "$RESOLUTION" ]]; then
        local w="${RESOLUTION%x*}"; local h="${RESOLUTION#*x}"
        filters="scale=$w:$h:force_original_aspect_ratio=decrease,pad=$w:$h:(ow-iw)/2:(oh-ih)/2"
    else
        filters="scale='trunc(iw/2)*2':'trunc(ih/2)*2'"
    fi

    # GIF Professional Engine (Palette Generation)
    if [[ "$FMT_LOWER" == "gif" ]]; then
        info "Generating High-Quality GIF with Palette..."
        ffmpeg -i "$INPUT" -y -hide_banner -loglevel error \
            -vf "$filters,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse" \
            "$OUTPUT_FILE"
        return
    fi

    # Standard Video Logic
    local cmd=(ffmpeg -i "$INPUT" -y -hide_banner -loglevel warning -vf "$filters")
    if [[ -n "$VIDEO_BITRATE" ]]; then
        cmd+=(-c:v libx264 -b:v "${VIDEO_BITRATE}k")
    elif [[ "$DISCORD_MODE" == true ]]; then
        info "Calculating Discord compression..."
        local dur=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$INPUT")
        if [[ -n "$dur" && "$dur" != "N/A" ]]; then
            local br=$(echo "($TARGET_SIZE * 8192 / $dur) - $AUDIO_BITRATE" | bc | cut -d'.' -f1)
            [[ $br -lt 150 ]] && br=150
            cmd+=(-c:v libx264 -b:v "${br}k" -maxrate "${br}k" -bufsize "$((br * 2))k")
        fi
    else
        cmd+=(-c:v libx264 -crf "$CRF" -preset fast)
    fi
    cmd+=(-c:a aac -b:a "${AUDIO_BITRATE}k" -pix_fmt yuv420p -movflags +faststart "$OUTPUT_FILE")
    "${cmd[@]}"
}

handle_audio() {
    local codec="libmp3lame"
    [[ "$FMT_LOWER" == "wav" ]] && codec="pcm_s16le"
    ffmpeg -i "$INPUT" -vn -y -hide_banner -loglevel error -c:a "$codec" -b:a "${AUDIO_BITRATE}k" "$OUTPUT_FILE"
}

handle_image() {
    local cmd=(ffmpeg -i "$INPUT" -y -hide_banner -loglevel error)
    
    # Explicitly specify the libwebp encoder for WebP files
    if [[ "$FMT_LOWER" == "webp" ]]; then
        cmd+=(-c:v libwebp)
    fi
    
    cmd+=("$OUTPUT_FILE")
    "${cmd[@]}"
}

handle_document() {
    local cmd=$(get_libre_cmd)
    [[ -z "$cmd" ]] && die "LibreOffice/soffice not found."
    info "Converting Document via $cmd..."
    "$cmd" --headless --convert-to "$FMT_LOWER" "$INPUT" --outdir "$(dirname "$OUTPUT_FILE")"
    local gen_file="$(dirname "$OUTPUT_FILE")/${NAME}.${FMT_LOWER}"
    [[ -f "$gen_file" && "$OUTPUT_FILE" != "$gen_file" ]] && mv "$gen_file" "$OUTPUT_FILE"
}

# --- Main Logic ---
info "Converting: $INPUT ➜ $OUTPUT_FILE"

case "$FMT_LOWER" in
    mp4|mkv|mov|webm|gif)       handle_video ;; # GIF is now allowed!
    mp3|wav|ogg|m4a)            handle_audio ;;
    png|jpg|jpeg|webp)          handle_image ;;
    pdf|docx|doc|ppt|pptx|odt)  handle_document ;;
    *) die "Unsupported format: $OUTPUT_FORMAT" ;;
esac

if [[ -f "$OUTPUT_FILE" ]]; then
    success "Success: $OUTPUT_FILE ($(du -h "$OUTPUT_FILE" | cut -f1))"
else
    die "Conversion failed."
fi
